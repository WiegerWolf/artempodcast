---
import ThemeToggle from './ThemeToggle.astro';
---

<header class="sticky top-0 z-50 bg-white/80 dark:bg-zinc-950/80 backdrop-blur-md border-b border-zinc-200 dark:border-zinc-800">
  <div class="max-w-3xl mx-auto px-4 sm:px-6 py-3 flex items-center justify-between">
    <a href="/" class="flex items-center gap-3 no-underline group">
      <img src="/logo.png" alt="ArtemPodcast" class="w-8 h-8" />
      <span class="text-lg font-bold text-zinc-900 dark:text-white tracking-wide uppercase">ArtemPodcast</span>
    </a>
    <div class="flex items-center gap-3">
      <a href="/index.xml" class="text-zinc-400 hover:text-orange-500 dark:hover:text-orange-400 transition-colors" title="RSS" aria-label="RSS Feed">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor">
          <circle cx="6.18" cy="17.82" r="2.18"/>
          <path d="M4 4.44v2.83c7.03 0 12.73 5.7 12.73 12.73h2.83c0-8.59-6.97-15.56-15.56-15.56zm0 5.66v2.83c3.9 0 7.07 3.17 7.07 7.07h2.83c0-5.47-4.43-9.9-9.9-9.9z"/>
        </svg>
      </a>
      <ThemeToggle />
    </div>
  </div>
</header>
