---
interface Props {
  slug: string;
  title: string;
  date: Date;
  num?: number;
}

const { slug, title, date, num } = Astro.props;
const formattedDate = date.toLocaleDateString('ru-RU', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<a href={`/${slug}/`} class="block group">
  <article class="bg-zinc-800/50 light:bg-white rounded-xl p-5 shadow-sm border border-zinc-700/50 light:border-zinc-200 transition-all duration-200 group-hover:border-indigo-500/50 group-hover:shadow-md group-hover:bg-zinc-800 light:group-hover:bg-zinc-50">
    <div class="flex items-start justify-between gap-4">
      <div class="min-w-0">
        <h2 class="text-lg font-semibold text-zinc-100 light:text-zinc-900 group-hover:text-indigo-400 light:group-hover:text-indigo-600 transition-colors truncate">
          {num !== undefined && <span class="text-zinc-500 font-normal">#{num} </span>}
          {title}
        </h2>
        <time class="text-sm text-zinc-500 light:text-zinc-400" datetime={date.toISOString()}>
          {formattedDate}
        </time>
      </div>
      <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-zinc-600 group-hover:text-indigo-400 transition-colors shrink-0 mt-1" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <polyline points="9 18 15 12 9 6"/>
      </svg>
    </div>
  </article>
</a>
