---
interface Props {
  slug: string;
  title: string;
  date: Date;
  num?: number | string;
}

const { slug, title, date, num } = Astro.props;
const formattedDate = date.toLocaleDateString('ru-RU', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<a href={`/${slug}/`} class="block group no-underline">
  <article class="rounded-xl px-5 py-4 border border-transparent transition-all duration-150 group-hover:bg-zinc-100 dark:group-hover:bg-zinc-800/60 group-hover:border-zinc-200 dark:group-hover:border-zinc-700/60">
    <div class="flex items-center justify-between gap-4">
      <div class="min-w-0">
        <h2 class="text-base font-medium text-zinc-900 dark:text-zinc-100 group-hover:text-indigo-600 dark:group-hover:text-indigo-400 transition-colors leading-snug">
          {num !== undefined && <span class="text-zinc-400 dark:text-zinc-500 font-normal">#{num}&ensp;</span>}
          {title}
        </h2>
        <time class="text-sm text-zinc-400 dark:text-zinc-500 mt-0.5 block" datetime={date.toISOString()}>
          {formattedDate}
        </time>
      </div>
      <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-zinc-300 dark:text-zinc-600 group-hover:text-indigo-500 dark:group-hover:text-indigo-400 transition-colors shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <polyline points="9 18 15 12 9 6"/>
      </svg>
    </div>
  </article>
</a>
