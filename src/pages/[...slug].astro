---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import PodcastPlayer from '../components/PodcastPlayer.astro';
import ScrollToTop from '../components/ScrollToTop.astro';

export async function getStaticPaths() {
  const episodes = await getCollection('episodes');
  return episodes.map((ep) => ({
    params: { slug: ep.id },
    props: { episode: ep },
  }));
}

const { episode } = Astro.props;
const { Content } = await render(episode);
const mediaBase = 'https://media.artempodcast.com/';
const audioUrl = mediaBase + episode.data.audio;
---

<BaseLayout title={episode.data.title}>
  <article>
    <a href="/" class="inline-flex items-center gap-1 text-sm text-zinc-500 hover:text-indigo-400 transition-colors mb-6">
      <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <polyline points="15 18 9 12 15 6"/>
      </svg>
      Назад
    </a>

    <h1 class="text-2xl font-bold mb-4 text-zinc-100 light:text-zinc-900">{episode.data.title}</h1>

    <time class="text-sm text-zinc-500 block mb-6" datetime={episode.data.date.toISOString()}>
      {episode.data.date.toLocaleDateString('ru-RU', { year: 'numeric', month: 'long', day: 'numeric' })}
    </time>

    <div class="mb-8">
      <PodcastPlayer src={audioUrl} title={episode.data.title} />
    </div>

    <div class="prose prose-lg max-w-none">
      <Content />
    </div>
  </article>
  <ScrollToTop />
</BaseLayout>
