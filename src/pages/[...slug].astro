---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import PodcastPlayer from '../components/PodcastPlayer.astro';
import ScrollToTop from '../components/ScrollToTop.astro';

export async function getStaticPaths() {
  const episodes = await getCollection('episodes');
  return episodes.map((ep) => ({
    params: { slug: ep.id },
    props: { episode: ep },
  }));
}

const { episode } = Astro.props;
const { Content } = await render(episode);
const mediaBase = 'https://media.artempodcast.com/';
const audioUrl = mediaBase + episode.data.audio;
---

<BaseLayout title={episode.data.title}>
  <article>
    <a href="/" class="inline-flex items-center gap-1.5 text-sm text-zinc-400 dark:text-zinc-500 hover:text-indigo-600 dark:hover:text-indigo-400 transition-colors mb-8 group">
      <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 group-hover:-translate-x-0.5 transition-transform" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <polyline points="15 18 9 12 15 6"/>
      </svg>
      Все выпуски
    </a>

    <h1 class="text-2xl sm:text-3xl font-bold mb-3 text-zinc-900 dark:text-zinc-100 leading-tight">{episode.data.title}</h1>

    <time class="text-sm text-zinc-400 dark:text-zinc-500 block mb-8" datetime={episode.data.date.toISOString()}>
      {episode.data.date.toLocaleDateString('ru-RU', { year: 'numeric', month: 'long', day: 'numeric' })}
    </time>

    <div class="mb-10">
      <PodcastPlayer src={audioUrl} title={episode.data.title} />
    </div>

    <div class="prose prose-zinc dark:prose-invert prose-lg max-w-none prose-a:text-indigo-600 dark:prose-a:text-indigo-400 prose-a:no-underline hover:prose-a:underline">
      <Content />
    </div>
  </article>
  <ScrollToTop />
</BaseLayout>
